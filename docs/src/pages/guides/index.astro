---
import DocsLayout from '@/layouts/DocsLayout.astro';
import { getCollection } from 'astro:content';

const guides = await getCollection('guides');
const sorted = guides.sort((a, b) => {
  const aOrder = a.data.sidebar?.order ?? 999;
  const bOrder = b.data.sidebar?.order ?? 999;
  return aOrder - bOrder;
});
---

<DocsLayout title="Guides" section="guides">
  <div class="docs-prose">
    <h1>Guides</h1>
    <p>Step-by-step tutorials and recipes for contributing to the platform.</p>

    <ul class="list-none space-y-3 p-0">
      {sorted.map((entry) => (
        <li class="m-0 p-0">
          <a
            href={`/guides/${entry.id}`}
            class="group block rounded-lg border bg-white p-4 transition hover:shadow-md"
            style="border-color: var(--color-border);"
          >
            <div class="mb-1 flex items-center gap-2">
              {entry.data.difficulty && (
                <span
                  class="rounded-full px-2 py-0.5 font-mono text-[10px] uppercase tracking-wider"
                  style="background-color: var(--color-primary-subtle); color: var(--color-primary-hover);"
                >
                  {entry.data.difficulty}
                </span>
              )}
              {entry.data.estimatedTime && (
                <span class="font-mono text-xs" style="color: var(--color-fg-subtle);">
                  {entry.data.estimatedTime}
                </span>
              )}
            </div>
            <h3
              class="m-0 font-display text-lg font-semibold"
              style="color: var(--color-fg);"
            >
              {entry.data.title}
              <span
                aria-hidden="true"
                class="ml-2 opacity-0 transition group-hover:translate-x-1 group-hover:opacity-100"
                style="color: var(--color-primary);"
              >→</span>
            </h3>
            {entry.data.description && (
              <p class="mt-1 text-sm" style="color: var(--color-fg-muted);">
                {entry.data.description}
              </p>
            )}
          </a>
        </li>
      ))}
    </ul>
  </div>
</DocsLayout>
