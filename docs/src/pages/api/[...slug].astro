---
import { getEntry, render } from 'astro:content';
import DocsLayout from '@/layouts/DocsLayout.astro';

const { slug } = Astro.params;
const entry = slug ? await getEntry('api', slug) : undefined;

if (!entry) {
  return new Response('Not Found', { status: 404 });
}

const { Content, headings } = await render(entry);

const methodColors: Record<string, string> = {
  GET: '#10b981',
  POST: '#0d9488',
  PUT: '#f59e0b',
  PATCH: '#3b82f6',
  DELETE: '#ef4444',
};
const methodColor = entry.data.method ? methodColors[entry.data.method] : '#475569';
---

<DocsLayout
  title={entry.data.title}
  description={entry.data.description}
  headings={headings}
  section="api"
  slug={entry.id}
>
  <div class="docs-prose">
    <div class="mb-4 flex items-center gap-2">
      {entry.data.method && (
        <span
          class="rounded-md px-2 py-0.5 font-mono text-xs font-semibold uppercase"
          style={`background-color: ${methodColor}; color: white;`}
        >
          {entry.data.method}
        </span>
      )}
      {entry.data.endpoint && (
        <code
          class="rounded-md px-2 py-0.5 font-mono text-sm"
          style="background-color: var(--color-bg-subtle); color: var(--color-fg);"
        >
          {entry.data.endpoint}
        </code>
      )}
      {entry.data.version && (
        <span
          class="rounded-full px-2 py-0.5 font-mono text-[10px] uppercase tracking-wider"
          style="background-color: var(--color-bg-subtle); color: var(--color-fg-subtle);"
        >
          {entry.data.version}
        </span>
      )}
      {entry.data.deprecated && (
        <span
          class="rounded-full px-2 py-0.5 font-mono text-[10px] uppercase tracking-wider"
          style="background-color: #fee2e2; color: #b91c1c;"
        >
          deprecated
        </span>
      )}
    </div>

    <h1>{entry.data.title}</h1>
    {entry.data.description && (
      <p class="lead" style="font-size: 1.125rem; color: var(--color-fg-muted); margin-top: -0.5rem;">
        {entry.data.description}
      </p>
    )}

    <Content />
  </div>
</DocsLayout>
