---
import AuthLayout from '@/layouts/AuthLayout.astro';
import { LoginForm } from '@/components/auth/LoginForm';

const redirect = Astro.url.searchParams.get('redirect') || '/';
---

<AuthLayout title="Sign in · Doxiq Docs">
  <main class="grain relative min-h-screen overflow-hidden">
    <div
      class="absolute inset-0 -z-10"
      style="background: radial-gradient(ellipse at top left, var(--color-primary-subtle) 0%, transparent 50%), radial-gradient(ellipse at bottom right, #fef3c7 0%, transparent 50%);"
    >
    </div>

    <div class="mx-auto flex min-h-screen max-w-6xl items-center px-6 py-12">
      <div class="grid w-full gap-12 lg:grid-cols-2 lg:items-center">
        <div class="hidden space-y-8 lg:block">
          <div class="flex items-center gap-3">
            <div
              class="flex h-10 w-10 items-center justify-center rounded-lg"
              style="background-color: var(--color-primary);"
            >
              <svg
                viewBox="0 0 24 24"
                fill="none"
                class="h-6 w-6"
                style="color: white;"
              >
                <path
                  d="M4 6h16M4 12h16M4 18h10"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                />
              </svg>
            </div>
            <div>
              <p class="text-sm font-medium" style="color: var(--color-fg-subtle);">
                Llamitai
              </p>
              <h1
                class="font-display text-2xl font-bold"
                style="color: var(--color-fg);"
              >
                Doxiq Docs
              </h1>
            </div>
          </div>

          <div class="space-y-4">
            <h2
              class="font-display text-4xl font-bold leading-tight tracking-tight"
              style="color: var(--color-fg);"
            >
              The Inspection Bench
              <br />
              <span style="color: var(--color-primary);">for your documents.</span>
            </h2>
            <p
              class="max-w-md text-lg leading-relaxed"
              style="color: var(--color-fg-muted);"
            >
              Internal documentation for the Doxiq platform — extraction rules,
              API references, deployment guides, and architectural decisions.
            </p>
          </div>

          <div class="grid grid-cols-2 gap-4 pt-4">
            <div
              class="rounded-lg border bg-white/60 p-4 backdrop-blur"
              style="border-color: var(--color-border);"
            >
              <p
                class="font-mono text-2xl font-bold"
                style="color: var(--color-primary);"
              >
                12
              </p>
              <p class="mt-1 text-sm" style="color: var(--color-fg-muted);">
                modules
              </p>
            </div>
            <div
              class="rounded-lg border bg-white/60 p-4 backdrop-blur"
              style="border-color: var(--color-border);"
            >
              <p
                class="font-mono text-2xl font-bold"
                style="color: var(--color-primary);"
              >
                86
              </p>
              <p class="mt-1 text-sm" style="color: var(--color-fg-muted);">
                endpoints
              </p>
            </div>
            <div
              class="rounded-lg border bg-white/60 p-4 backdrop-blur"
              style="border-color: var(--color-border);"
            >
              <p
                class="font-mono text-2xl font-bold"
                style="color: var(--color-primary);"
              >
                24
              </p>
              <p class="mt-1 text-sm" style="color: var(--color-fg-muted);">
                ADRs
              </p>
            </div>
            <div
              class="rounded-lg border bg-white/60 p-4 backdrop-blur"
              style="border-color: var(--color-border);"
            >
              <p
                class="font-mono text-2xl font-bold"
                style="color: var(--color-primary);"
              >
                v1.2
              </p>
              <p class="mt-1 text-sm" style="color: var(--color-fg-muted);">
                platform
              </p>
            </div>
          </div>
        </div>

        <div class="mx-auto w-full max-w-md">
          <div
            class="rounded-xl border bg-white p-8 shadow-lg"
            style="border-color: var(--color-border);"
          >
            <div class="mb-6 flex items-center gap-2 lg:hidden">
              <div
                class="flex h-8 w-8 items-center justify-center rounded-md"
                style="background-color: var(--color-primary);"
              >
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  class="h-5 w-5"
                  style="color: white;"
                >
                  <path
                    d="M4 6h16M4 12h16M4 18h10"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                  />
                </svg>
              </div>
              <span class="font-display text-lg font-bold">Doxiq Docs</span>
            </div>

            <h2
              class="font-display text-2xl font-bold"
              style="color: var(--color-fg);"
            >
              Sign in
            </h2>
            <p class="mt-1 text-sm" style="color: var(--color-fg-muted);">
              Use your Doxiq account credentials.
            </p>

            <div class="mt-6">
              <LoginForm client:load redirect={redirect} />
            </div>

            <p
              class="mt-6 text-center text-xs"
              style="color: var(--color-fg-subtle);"
            >
              Authenticated via the Doxiq backend
            </p>
          </div>

          <p
            class="mt-6 text-center text-xs"
            style="color: var(--color-fg-subtle);"
          >
            © 2026 Llamitai · Internal use only
          </p>
        </div>
      </div>
    </div>
  </main>
</AuthLayout>
