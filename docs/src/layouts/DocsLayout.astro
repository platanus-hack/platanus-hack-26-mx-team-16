---
import '@/styles/globals.css';
import { Sidebar } from '@/components/layout/Sidebar';
import { Topbar } from '@/components/layout/Topbar';
import { TableOfContents } from '@/components/layout/TableOfContents';

interface Heading {
  slug: string;
  text: string;
  depth: number;
}

interface Props {
  title: string;
  description?: string;
  headings?: Heading[];
  section?: 'docs' | 'guides' | 'api';
  slug?: string;
}

const {
  title,
  description,
  headings = [],
  section = 'docs',
  slug = '',
} = Astro.props;

const session = Astro.locals.session;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description || title} />
    <title>{title} · Doxiq Docs</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Figtree:wght@300..900&family=Geist+Mono:wght@300..700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen" style="background-color: var(--color-bg);">
    <div class="flex min-h-screen flex-col">
      <Topbar client:load user={session} />

      <div class="flex flex-1">
        <aside
          class="sticky top-16 hidden h-[calc(100vh-4rem)] w-64 shrink-0 overflow-y-auto border-r lg:block"
          style="border-color: var(--color-border); background-color: var(--color-bg-elevated);"
        >
          <Sidebar client:load section={section} currentSlug={slug} />
        </aside>

        <main class="flex-1 px-6 py-10 lg:px-12">
          <article class="mx-auto max-w-3xl">
            <slot />
          </article>
        </main>

        <aside
          class="sticky top-16 hidden h-[calc(100vh-4rem)] w-56 shrink-0 overflow-y-auto px-4 py-10 xl:block"
        >
          <TableOfContents client:load headings={headings} />
        </aside>
      </div>
    </div>
  </body>
</html>
