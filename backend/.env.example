# -> GENERAL
STAGE=dev  # Options: dev, staging, production
ENVIRONMENT=development  # Options: development, staging, production
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:8200

# -> GOOGLE LOGIN
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
# Must match the frontend GOOGLE_REDIRECT_URI and the Google Console (callback page).
GOOGLE_REDIRECT_URI=http://localhost:3000/login/callback

# -> JWT CONFIG
JWT_SECRET_KEY=your-jwt-secret-key-here  # openssl rand -hex 16
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days (60 * 24 * 7)
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=43200  # 30 days (60 * 24 * 30)
JWT_ALGORITHM=HS256

# -> COMMON
SECRET_KEY=    # openssl rand -base64 32 | tr '+/' '-_' | tr -d '\n'

# -> DATABASES
POSTGRES_USER=postgres
POSTGRES_DB=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_PASSWORD=postgres
REDIS_HOST=redis
REDIS_USER=
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_DB=0

# -> NOTIFICATIONS (Email Configuration)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_TLS=true
SMTP_USERNAME=your-email-user
SMTP_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=noreply@example.com

# -> STORAGE (AWS S3 Configuration)
AWS_S3_ENDPOINT_URL=  # Optional: for MinIO or custom S3-compatible endpoints
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_S3_REGION_NAME=us-east-1
AWS_STORAGE_BUCKET_NAME=your-bucket-name
AWS_CLOUDFRONT_DOMAIN=https://your-cloudfront-domain.com

# -> MONITORING
SENTRY_DSN=
SENTRY_ENVIRONMENT=dev  # Options: dev, staging, production
SENTRY_TRACES_SAMPLE_RATE=0.1  # 10% of transactions
SENTRY_PROFILES_SAMPLE_RATE=0.1  # 10% of transactions
SENTRY_SEND_DEFAULT_PII=false  # GDPR compliance

# -> FRONTEND
FRONTEND_HOST=http://localhost:3000

# -> ADMIN
ADMIN_LOGO_URL=https://preview.tabler.io/static/logo-white.svg
ADMIN_LOGIN_LOGO_URL=https://preview.tabler.io/static/logo.svg

# -> GOOGLE APIs
GOOGLE_CERTS_URL=https://www.googleapis.com/oauth2/v3/certs

# -> TEMPORAL WORKER
DOCUMENT_URI=s3://your-bucket/path/to/document.pdf

# -> AGENT TEAM / MODEL PROVIDER (05-agent-team)
# MODEL_PROVIDER swaps the whole Agno Team (coordinator + members + agentic judge):
#   anthropic (default) → Claude via ANTHROPIC_API_KEY + OPUS_MODEL_ID/SONNET_MODEL_ID
#   minimax             → MiniMax  (OpenAI-compatible)  via MINIMAX_* below
#   glm                 → Zhipu/GLM (OpenAI-compatible)  via GLM_* below
MODEL_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPUS_MODEL_ID=claude-opus-4-8
SONNET_MODEL_ID=claude-sonnet-4-6
# MiniMax (set MODEL_PROVIDER=minimax). One model id serves both tiers.
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL_ID=MiniMax-M2
# GLM / Zhipu / Z.ai (set MODEL_PROVIDER=glm). CN region: https://open.bigmodel.cn/api/paas/v4
GLM_API_KEY=
GLM_BASE_URL=https://api.z.ai/api/paas/v4
GLM_MODEL_ID=glm-4.6
