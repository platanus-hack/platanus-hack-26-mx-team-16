      ],
      "method": "LLM_CHECK",
      "params": {
        "context_lookup": {
          "from": "#giros_sii_por_rut",
          "by": "@invoice.emisor.rut",
          "extract": [
            "giro_principal",
            "giros_secundarios"
          ]
        },
        "judgement": "Para cada items[].descripcion, decidir si es una actividad razonablemente compatible con giro_principal o alguno de giros_secundarios."
