[
  {
    "uuid": "36aab742-879e-4a3b-b688-5bdb5702ac0b",
    "name": "Cedula de Identidad",
    "description": "Documento de identificacion personal",
    "fields": {
      "type": "object",
      "properties": {
        "nombres": {
          "type": "string",
          "description": "Nombres de la persona"
        },
        "apellidos": {
          "type": "string",
          "description": "Apellidos de la persona"
        },
        "numero_cedula": {
          "type": "string",
          "description": "Numero de cedula de identidad"
        },
        "fecha_nacimiento": {
          "type": "string",
          "format": "date",
          "description": "Fecha de nacimiento"
        },
        "sexo": {
          "type": "string",
          "description": "Sexo de la persona"
        }
