        "enabled": true
      },
      {
        "id": "v-fecha-nacimiento",
        "prompt": "Verifica que {{fecha_nacimiento}} tenga formato DD/MM/AAAA y sea una fecha valida.",
        "enabled": true
      },
      {
        "id": "v-numero-cedula",
        "prompt": "Verifica que {{numero_cedula}} contenga entre 7 y 9 digitos numericos.",
        "enabled": true
      }
    ]
  }
