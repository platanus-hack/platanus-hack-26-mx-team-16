{
  "schemaVersion": "1.0",
  "kind": "workflow_bundle",
  "slug": "circular-judicial",
  "name": "Circular Judicial",
  "description": "Expediente de circulares judiciales con revisión humana en dos niveles (L1 obligatoria, L2 por excepción) y aprobación final. Caso 3.",
  "industry": null,
  "workflow": {
    "name": "Circular Judicial",
    "slug": "circular-judicial",
    "workflowType": "ANALYSIS",
    "outputSchema": null,
    "caseNoun": {
      "es": { "one": "Oficio", "other": "Oficios" },
      "en": { "one": "Court Order", "other": "Court Orders" }
    }
  },
  "documentTypes": [
    {
      "name": "Circular",
      "slug": "circular",
      "description": "Circular o comunicación judicial a clasificar y analizar.",
      "keywords": ["circular", "juzgado", "expediente", "oficio"],
      "examples": [],
      "fields": {
        "type": "object",
        "properties": {
          "numero_expediente": { "type": "string", "description": "Número de expediente" },
          "juez_nombre": { "type": "string", "description": "Nombre del juez" },
          "juzgado": { "type": "string", "description": "Juzgado emisor" },
          "fecha": { "type": "string", "description": "Fecha de la circular" },
          "asunto": { "type": "string", "description": "Asunto o materia" }
        }
      },
      "validation_rules": [
        {
          "id": "expediente-presente",
          "name": "Número de expediente presente",
          "prompt": "La circular debe incluir un número de expediente.",
          "enabled": true
        }
      ]
    }
  ],
  "pipeline": {
    "slug": "circular-judicial-case",
    "name": "Circular judicial (revisión L1/L2 + aprobación)",
    "kind": "ANALYSIS",
    "outputSchema": null,
    "phases": [
      { "id": "ingest", "kind": "ingest", "config": {} },
      { "id": "extract_text", "kind": "extract_text", "config": { "extractor": "textract_layout" } },
      { "id": "classify_pages", "kind": "classify_pages", "config": {} },
      { "id": "extract_fields", "kind": "extract_fields", "config": {} },
      { "id": "assess", "kind": "assess", "config": {} },
      { "id": "validate_extraction", "kind": "validate_extraction", "config": {} },
      { "id": "finalize", "kind": "finalize", "config": {} },
      { "id": "await_documents", "kind": "await_documents", "config": { "required_types": { "circular": 1 } } },
      { "id": "extraction_gate", "kind": "extraction_gate", "config": { "activation": { "field_thresholds": { "default": 0.8, "juez_nombre": 0.85 }, "on_low_confidence": "review", "blocking_rule_severities": ["BLOCKER"], "sample_rate": 0, "mode": "mandatory", "stages": [ { "stage": "review_l1", "mode": "mandatory" }, { "stage": "review_l2", "mode": "by_exception" } ] } } },
      { "id": "analyze", "kind": "analyze", "config": {} },
      { "id": "approval", "kind": "human_review", "config": { "kind": "approval" } },
      { "id": "output", "kind": "output", "config": {} },
      { "id": "deliver", "kind": "deliver", "config": {} }
    ]
  },
  "rules": [
    {
      "name": "Expediente presente",
      "slug": "expediente_presente",
      "kind": "VALIDATION",
      "prompt": "Verifica que la circular tenga un número de expediente (@circular.numero_expediente) no vacío.",
      "when": null,
      "config": { "severity": "BLOCKER" },
      "scope": { "mode": "ALL_DOCUMENTS", "on_empty": "SKIPPED", "document_type_slug": "circular" },
      "knowledge_refs_external": [],
      "position": 0,
      "is_active": true
    }
  ],
  "requiresConfiguration": ["destinations", "sources"]
}
