# Backend API Configuration
NEXT_PUBLIC_BACKEND_API_HOST=http://localhost:8000
BACKEND_API_HOST=http://localhost:8000

# API Key (Server-side only)
BACKEND_API_KEY=your-api-key-here

# App Version
NEXT_PUBLIC_VERSION=1.0.0

# App URL (for metadata and Open Graph images)
NEXT_PUBLIC_APP_URL=https://llamitai.com

# Google OAuth (server-only — never inline into the client bundle).
# Must match the backend GOOGLE_* vars and the Google Console authorized URIs.
# GOOGLE_REDIRECT_URI must equal the callback page path (/login/callback).
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_REDIRECT_URI=http://localhost:3000/login/callback

# Node Environment
NODE_ENV=development

SENTRY_DSN=
