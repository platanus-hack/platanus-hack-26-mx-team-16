# pnpm 11+ trata los "ignored build scripts" como error (exit 1) cuando se
# usa --frozen-lockfile y el lockfile no registra la aprobación de
# package.json/pnpm.onlyBuiltDependencies. Volvemos al comportamiento
# antiguo (warning, no error) para que el build de Docker no falle.
#
# Los paquetes que sí deben ejecutar sus scripts (@swc/core,
# @parcel/watcher) se siguen declarando en package.json bajo
# `pnpm.onlyBuiltDependencies`.
strict-dep-builds=false
