# =============================================================================
# Docker build context exclusions
#
# Goal: keep the build context tiny and reproducible.
# The Dockerfile copies only what's needed in each stage; everything below is
# either re-built inside the container, irrelevant to the runtime image, or
# secret material that should come from the orchestrator (Portainer env_data).
# =============================================================================

# --- Dependencies (installed inside the container) --------------------------
node_modules
**/node_modules
.pnpm-store
.yarn
.npm
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Build outputs (regenerated by `pnpm build`) ----------------------------
.next
**/.next
out
dist
build
.turbo
.vercel
tsconfig.tsbuildinfo
**/*.tsbuildinfo

# --- Testing (not needed in production image) -------------------------------
coverage
.nyc_output
__tests__
__mocks__
e2e
test-results
playwright-report
.playwright-mcp
vitest.config.ts
playwright.config.ts
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx

# --- Lint / format / type-check config (build doesn't need them) ------------
biome.json
.editorconfig
.eslintrc*
.prettier*

# --- Local dev tooling (Claude, Cursor, editors) ----------------------------
.claude
.cursor
.vscode
.idea
.husky
.devcontainer
skills-lock.json
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Git metadata -----------------------------------------------------------
.git
.gitignore
.gitattributes
.github
.gitlab-ci.yml

# --- Documentation ----------------------------------------------------------
README.md
CHANGELOG.md
CONTRIBUTING.md
LICENSE*
docs
**/*.md

# --- Docker / compose (used by the host, not by the image) ------------------
Dockerfile
Dockerfile.*
.dockerignore
docker-compose*.yml
docker-compose*.yaml

# --- Environment files (secrets must come from Portainer env_data) ----------
.env
.env.*
!.env.example

# --- Misc -------------------------------------------------------------------
*.pem
*.key
*.log
.cache
tmp
temp
.local
*.tgz
